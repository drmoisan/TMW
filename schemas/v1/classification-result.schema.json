{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["label", "confidence"],
  "properties": {
    "label": {
      "type": "string",
      "enum": ["HighPriority", "Promotional", "General"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    }
  },
  "additionalProperties": false
}
