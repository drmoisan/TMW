{
  "name": "office-addin-taskpane",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/OfficeDev/Office-Addin-TaskPane.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "outlook",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "postinstall": "patch-package",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "depcruise": "depcruise --config .dependency-cruiser.cjs src",
    "dev-server": "webpack serve --mode development",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "generate:api": "openapi-typescript artifacts/openapi/current.json --output src/api-client/v1.ts",
    "lint": "office-addin-lint check",
    "lint:fix": "office-addin-lint fix",
    "lint:openapi": "spectral lint artifacts/openapi/current.json --ruleset .spectral.yaml",
    "prettier": "office-addin-lint prettier",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "office-addin-debugging start manifest.json",
    "stop": "office-addin-debugging stop manifest.json",
    "validate": "office-addin-manifest validate manifest.json",
    "validate:xml": "office-addin-manifest validate manifest.xml",
    "watch": "webpack --mode development --watch"
  },
  "dependencies": {
    "core-js": "^3.36.0",
    "openapi-fetch": "^0.13.5",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@fast-check/vitest": "0.3.0",
    "@playwright/test": "^1.49.1",
    "@stoplight/spectral-cli": "^6.15.0",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.25.4",
    "@babel/preset-typescript": "^7.23.3",
    "@types/office-js": "^1.0.377",
    "@types/office-runtime": "^1.0.35",
    "@vitest/coverage-v8": "^2.1.9",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^12.0.2",
    "dependency-cruiser": "^16.10.4",
    "fast-check": "4.8.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-office-addins": "^4.0.7",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-security": "^3.0.1",
    "file-loader": "^6.2.0",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "jsdom": "^25.0.1",
    "msw": "^2.14.5",
    "office-addin-cli": "^2.0.3",
    "office-addin-debugging": "^6.0.3",
    "office-addin-dev-certs": "^2.0.3",
    "office-addin-lint": "^3.0.3",
    "office-addin-manifest": "^2.0.3",
    "office-addin-prettier-config": "^2.0.1",
    "openapi-typescript": "^7.5.0",
    "os-browserify": "^0.3.0",
    "patch-package": "^8.0.1",
    "process": "^0.11.10",
    "source-map-loader": "^5.0.0",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.1.9",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "5.1.0"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 versions",
    "ie 11"
  ]
}
