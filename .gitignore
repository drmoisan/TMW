# Dependencies
node_modules/

# Build output
dist/
build/
out/
coverage/
.nyc_output/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example

# Office add-in local certificates and debug artifacts
.office-addin-dev-certs/
.office-addin-debugging/

# TypeScript and tool caches
*.tsbuildinfo
.eslintcache
.cache/
.parcel-cache/

# Test artifacts
test-results/
playwright-report/
mutation-report/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor and IDE state
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
# MSBuild language-service cache, regenerated locally by `dotnet build`.
*.lscache

# Temporary artifacts
# `artifacts/*` (rather than `artifacts/`) ignores the directory contents while
# leaving the directory traversable, so the committed OpenAPI contract snapshot
# (Issue #19) can be re-included below. Git cannot re-include files under a
# fully ignored parent directory.
artifacts/*
!artifacts/openapi/
!artifacts/openapi/*

# .NET build and test output
**/bin/
**/obj/
**/TestResults/
.vs/artifacts/csharp/

# Playwright E2E auth state (generated at runtime by tests/e2e/auth.setup.ts;
# contains bearer tokens — must never be committed).
tests/e2e/.auth/
test-results/
playwright-report/

# Verify snapshot received files (temporary, never committed)
*.received.*
*.received/
