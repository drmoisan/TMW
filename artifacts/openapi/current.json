{
  "openapi": "3.1.1",
  "info": {
    "title": "TaskMaster.Api | v1",
    "version": "1.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "TaskMaster.Api"
        ],
        "description": "Returns the service health status. Anonymous; used by infrastructure probes.",
        "operationId": "Health",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/ping": {
      "get": {
        "tags": [
          "TaskMaster.Api"
        ],
        "description": "Authenticated connectivity probe. Returns a fixed PingResponse payload.",
        "operationId": "Ping",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PingResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/classify": {
      "post": {
        "tags": [
          "TaskMaster.Api"
        ],
        "description": "Classifies a mail message and returns a label with a confidence score. Returns 422 when the request is missing a message id or subject.",
        "operationId": "Classify",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClassifyRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClassifyResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity"
          }
        }
      }
    },
    "/api/classify/feedback": {
      "post": {
        "tags": [
          "TaskMaster.Api"
        ],
        "description": "Records user feedback for a prior classification to inform future training. Returns 204 No Content on success.",
        "operationId": "ClassifyFeedback",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FeedbackRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "No Content"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ClassifyRequest": {
        "required": [
          "messageId",
          "subject",
          "body"
        ],
        "type": "object",
        "properties": {
          "messageId": {
            "type": [
              "null",
              "string"
            ]
          },
          "subject": {
            "type": [
              "null",
              "string"
            ]
          },
          "body": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ClassifyResponse": {
        "required": [
          "label",
          "confidence"
        ],
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "confidence": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "FeedbackRequest": {
        "required": [
          "messageId",
          "label",
          "confirmed"
        ],
        "type": "object",
        "properties": {
          "messageId": {
            "type": [
              "null",
              "string"
            ]
          },
          "label": {
            "type": [
              "null",
              "string"
            ]
          },
          "confirmed": {
            "type": "boolean"
          }
        }
      },
      "HealthResponse": {
        "required": [
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "PingResponse": {
        "required": [
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "TaskMaster.Api"
    }
  ]
}